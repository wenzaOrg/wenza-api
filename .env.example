APP_NAME=Wenza
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Africa/Lagos
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_NG

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=wenza
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=wenza_

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Sanctum (API token mode — no stateful domains needed for pure API)
SANCTUM_STATEFUL_DOMAINS=

# CORS — frontend origins
FRONTEND_URL=http://localhost:3000
APP_FRONTEND_URL=http://localhost:3001
CERT_FRONTEND_URL=http://localhost:3002
SCHOLARSHIP_FRONTEND_URL=http://localhost:3003

# Mail — use log driver for local development
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=hello@wenza.com
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=

# Payments — Paystack test keys (fill in your test keys)
PAYSTACK_SECRET_KEY=sk_test_
PAYSTACK_PUBLIC_KEY=pk_test_
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/google/callback

# File Storage — local for development, R2 for production
FILESYSTEM_DISK=local
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=wenza
R2_ENDPOINT=
R2_URL=

# Certificate verification URL (used in QR code)
CERT_URL=http://localhost:3002

# Sentry
SENTRY_LARAVEL_DSN=

VITE_APP_NAME="${APP_NAME}"
